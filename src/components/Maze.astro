---
const LABEL = "HUW HALLAM · DATA SCIENTIST";
---

<section class="maze-section" aria-label="Interactive name maze">
  <noscript>
    <h1 class="hand maze-fallback">{LABEL}</h1>
  </noscript>
  <div class="maze-wrap" id="maze-wrap">
    <svg
      id="maze-svg"
      viewBox="0 0 632 488"
      aria-hidden="true"
      style="opacity:0; transition: opacity 0.4s;"
    ></svg>
    <p class="hand maze-hint" id="maze-hint">click or drag to guide the string through the maze</p>
  </div>
  <h1 class="hand maze-title" id="maze-title" aria-live="polite"></h1>
</section>

<script>
import rough from 'roughjs';

// ── Constants ──────────────────────────────────────────────────────────────
const COLS = 12, ROWS = 8, CELL = 48;
const PL = 28, PR = 28, PT = 52, PB = 52;

const LABEL  = "HUW HALLAM · DATA SCIENTIST";
const chars  = LABEL.split('');
const N      = chars.length;

// Entry = bottom-right, Exit = top-left
const START_R = ROWS - 1, START_C = COLS - 1;
const END_R   = 0,        END_C   = 0;

const INK    = '#2a1f14';
const ACCENT = '#c96a2b';
const BG     = '#faf6ef';
const SVG_NS = 'http://www.w3.org/2000/svg';

// ── Seeded PRNG ─────────────────────────────────────────────────────────────
function makePRNG(seed: number) {
  let s = seed;
  return () => {
    s = (s + 0x6D2B79F5) | 0;
    let t = Math.imul(s ^ (s >>> 15), 1 | s);
    t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  };
}

// ── Maze generation (iterative DFS) ─────────────────────────────────────────
// hOpen[r][c] = passage between (r,c) and (r+1,c)
// vOpen[r][c] = passage between (r,c) and (r,c+1)
function generateMaze(rng: () => number) {
  const hOpen: boolean[][] = Array.from({ length: ROWS-1 }, () => Array(COLS).fill(false));
  const vOpen: boolean[][] = Array.from({ length: ROWS },   () => Array(COLS-1).fill(false));
  const vis: boolean[][]   = Array.from({ length: ROWS },   () => Array(COLS).fill(false));

  const shuffle = <T>(a: T[]) => {
    for (let i = a.length - 1; i > 0; i--) {
      const j = Math.floor(rng() * (i + 1));
      [a[i], a[j]] = [a[j], a[i]];
    }
    return a;
  };

  const stack: [number,number][] = [[START_R, START_C]];
  vis[START_R][START_C] = true;

  while (stack.length) {
    const [r, c] = stack[stack.length - 1];
    const ns = shuffle(
      ([[r-1,c],[r+1,c],[r,c-1],[r,c+1]] as [number,number][])
        .filter(([nr,nc]) => nr>=0 && nr<ROWS && nc>=0 && nc<COLS && !vis[nr][nc])
    );
    if (!ns.length) { stack.pop(); continue; }
    const [nr, nc] = ns[0];
    vis[nr][nc] = true;
    if      (nr === r-1) hOpen[nr][c]  = true;
    else if (nr === r+1) hOpen[r][c]   = true;
    else if (nc === c-1) vOpen[r][nc]  = true;
    else                 vOpen[r][c]   = true;
    stack.push([nr, nc]);
  }
  return { hOpen, vOpen };
}

// ── BFS distance from every cell to EXIT ────────────────────────────────────
function computeDist(hOpen: boolean[][], vOpen: boolean[][]): number[][] {
  const dist: number[][] = Array.from({ length: ROWS }, () => Array(COLS).fill(Infinity));
  dist[END_R][END_C] = 0;
  const q: [number,number][] = [[END_R, END_C]];
  for (let qi = 0; qi < q.length; qi++) {
    const [r, c] = q[qi];
    const moves: [number,number,boolean][] = [
      [r-1,c, r>0        && hOpen[r-1][c]],
      [r+1,c, r<ROWS-1   && hOpen[r][c]],
      [r,c-1, c>0        && vOpen[r][c-1]],
      [r,c+1, c<COLS-1   && vOpen[r][c]],
    ];
    for (const [nr,nc,open] of moves) {
      if (open && dist[nr][nc] === Infinity) {
        dist[nr][nc] = dist[r][c] + 1;
        q.push([nr,nc]);
      }
    }
  }
  return dist;
}

// ── Coord helpers ─────────────────────────────────────────────────────────────
const cx = (c: number) => PL + c * CELL + CELL / 2;
const cy = (r: number) => PT + r * CELL + CELL / 2;

// Interpolate pixel position at float index along a trail of cells
function trailPos(trail: [number,number][], t: number): { x: number; y: number } {
  const n = trail.length - 1;
  if (n <= 0) return { x: cx(trail[0][1]), y: cy(trail[0][0]) };
  const clamped = Math.max(0, Math.min(n - 0.0001, t));
  const lo = Math.floor(clamped);
  const f  = clamped - lo;
  const [r0,c0] = trail[lo];
  const [r1,c1] = trail[Math.min(lo+1, n)];
  return { x: cx(c0)+(cx(c1)-cx(c0))*f, y: cy(r0)+(cy(r1)-cy(r0))*f };
}

// ── Main ──────────────────────────────────────────────────────────────────────
const svg = document.getElementById('maze-svg') as SVGSVGElement;

document.fonts.ready.then(() => {
  const rng = makePRNG(Date.now());
  const { hOpen, vOpen } = generateMaze(rng);
  const dist  = computeDist(hOpen, vOpen);
  const maxDist = dist[START_R][START_C]; // BFS distance from start to exit

  // Trail: sequence of cells the lead has moved through.
  // headTarget: integer index in trail (where lead is heading).
  // headFloat:  animated float catching up to headTarget.
  const trail: [number,number][] = [[START_R, START_C]];
  let headTarget = 0;
  let headFloat  = 0;

  // ── Spread & rotation helpers ───────────────────────────────────────────────
  // Returns 0..1: how close the lead is to the exit (0=at start, 1=at exit)
  function leadProximity(): number {
    const [r,c] = trail[headTarget];
    return maxDist > 0 ? Math.max(0, 1 - dist[r][c] / maxDist) : 0;
  }

  // Spread fraction: 0 = all together, 1 = normal text spacing.
  // Kicks in only in the last ~45% of the solution path.
  function spreadFraction(): number {
    const p = leadProximity();
    return Math.max(0, Math.min(1, (p - 0.55) / 0.45));
  }

  // Rotation amplitude: 1 = full chaos, 0 = upright.
  // Stays near 1 for most of the journey, fades in the last ~25%.
  function rotAmp(charProx: number): number {
    return Math.max(0, Math.min(1, 1 - charProx / 0.25));
  }

  // ── Navigation ─────────────────────────────────────────────────────────────
  function wallOpen(r: number, c: number, dir: string): boolean {
    if (dir === 'up')    return r > 0        && hOpen[r-1][c];
    if (dir === 'down')  return r < ROWS-1   && hOpen[r][c];
    if (dir === 'left')  return c > 0        && vOpen[r][c-1];
    if (dir === 'right') return c < COLS-1   && vOpen[r][c];
    return false;
  }

  function tryMove(dir: string) {
    if (Math.abs(headFloat - headTarget) > 0.6) return; // still animating
    const [r, c] = trail[headTarget];
    const [nr, nc]: [number,number] =
      dir === 'up'    ? [r-1, c] :
      dir === 'down'  ? [r+1, c] :
      dir === 'left'  ? [r, c-1] : [r, c+1];

    if (!wallOpen(r, c, dir)) return;

    // Moving back along trail?
    if (headTarget > 0) {
      const [pr, pc] = trail[headTarget - 1];
      if (nr === pr && nc === pc) { headTarget--; return; }
    }
    // Moving forward: trim any forward history then push new cell
    trail.splice(headTarget + 1);
    trail.push([nr, nc]);
    headTarget++;
  }

  // ── Mouse / touch state ─────────────────────────────────────────────────────
  let mouseHeld = false;
  let mouseX = 0, mouseY = 0;
  let lastMoveMs = 0;
  const MOVE_INTERVAL = 170; // ms between steps

  function domCoords(e: MouseEvent | Touch): { x: number; y: number } {
    const rect = svg.getBoundingClientRect();
    const scaleX = 632 / rect.width;
    const scaleY = 488 / rect.height;
    return { x: (e.clientX - rect.left) * scaleX, y: (e.clientY - rect.top) * scaleY };
  }

  svg.addEventListener('mousedown', e => {
    mouseHeld = true;
    const p = domCoords(e); mouseX = p.x; mouseY = p.y;
  });
  svg.addEventListener('touchstart', e => {
    e.preventDefault();
    mouseHeld = true;
    const p = domCoords(e.touches[0]); mouseX = p.x; mouseY = p.y;
  }, { passive: false });
  window.addEventListener('mousemove', e => {
    if (!mouseHeld) return;
    const p = domCoords(e); mouseX = p.x; mouseY = p.y;
  });
  window.addEventListener('touchmove', e => {
    const p = domCoords(e.touches[0]); mouseX = p.x; mouseY = p.y;
  }, { passive: true });
  window.addEventListener('mouseup',  () => { mouseHeld = false; });
  window.addEventListener('touchend', () => { mouseHeld = false; });

  function dirTowardMouse(): string | null {
    const [r, c] = trail[headTarget];
    const dx = mouseX - cx(c), dy = mouseY - cy(r);
    if (Math.abs(dx) < 6 && Math.abs(dy) < 6) return null;
    return Math.abs(dx) > Math.abs(dy)
      ? (dx > 0 ? 'right' : 'left')
      : (dy > 0 ? 'down'  : 'up');
  }

  // ── Draw maze walls ─────────────────────────────────────────────────────────
  const rc   = rough.svg(svg);
  const opts = { stroke: INK, strokeWidth: 1.8, roughness: 1.6, bowing: 0.8 };

  (() => {
    const mazeL = PL, mazeR = PL + COLS * CELL;
    const mazeT = PT, mazeB = PT + ROWS * CELL;

    // Entry gap: bottom border at START_C (col 11 = rightmost)
    const egL = PL + START_C * CELL + 4, egR = PL + (START_C+1) * CELL - 4;
    // Exit gap: top border at END_C (col 0 = leftmost)
    const xgL = PL + END_C * CELL + 4,   xgR = PL + (END_C+1) * CELL - 4;

    // Outer border with gaps
    svg.appendChild(rc.line(mazeL,  mazeB, egL,   mazeB, opts)); // bottom-left section
    svg.appendChild(rc.line(egR,    mazeB, mazeR, mazeB, opts)); // bottom-right section
    svg.appendChild(rc.line(xgR,    mazeT, mazeR, mazeT, opts)); // top-right section
    svg.appendChild(rc.line(mazeL,  mazeT, xgL,   mazeT, opts)); // top-left section (with gap)
    svg.appendChild(rc.line(mazeL,  mazeT, mazeL, mazeB, opts)); // left wall
    svg.appendChild(rc.line(mazeR,  mazeT, mazeR, mazeB, opts)); // right wall

    // Interior horizontal walls
    for (let r = 0; r < ROWS-1; r++)
      for (let c = 0; c < COLS; c++)
        if (!hOpen[r][c])
          svg.appendChild(rc.line(PL+c*CELL, PT+(r+1)*CELL, PL+(c+1)*CELL, PT+(r+1)*CELL, opts));

    // Interior vertical walls
    for (let r = 0; r < ROWS; r++)
      for (let c = 0; c < COLS-1; c++)
        if (!vOpen[r][c])
          svg.appendChild(rc.line(PL+(c+1)*CELL, PT+r*CELL, PL+(c+1)*CELL, PT+(r+1)*CELL, opts));
  })();

  // ── Draw arrow (entry) and crown (exit) ─────────────────────────────────────
  (() => {
    const aOpts = { stroke: ACCENT, strokeWidth: 2.2, roughness: 1.2, bowing: 0.5 };

    // Arrow below bottom-right (pointing up into maze)
    const ax = cx(START_C), ay = PT + ROWS * CELL + 12;
    svg.appendChild(rc.line(ax, ay+26, ax, ay+4,  aOpts));
    svg.appendChild(rc.line(ax-9, ay+16, ax, ay+4, aOpts));
    svg.appendChild(rc.line(ax+9, ay+16, ax, ay+4, aOpts));

    // Crown above top-left (exit)
    const kx = cx(END_C), ky = PT - 12;
    const cp =
      `M ${kx-17} ${ky} L ${kx-17} ${ky-13} L ${kx-8} ${ky-7} ` +
      `L ${kx} ${ky-17} L ${kx+8} ${ky-7} L ${kx+17} ${ky-13} L ${kx+17} ${ky} Z`;
    svg.appendChild(rc.path(cp, { ...aOpts, fill: 'none' }));
  })();

  // ── Character elements ────────────────────────────────────────────────────
  const initRot = Array.from({ length: N }, () => (Math.random()*2-1) * 50);

  const charEls: SVGTextElement[] = chars.map(ch => {
    const el = document.createElementNS(SVG_NS, 'text');
    el.textContent = ch === ' ' ? '\u00a0' : ch;
    el.setAttribute('font-family',       "'Caveat', cursive");
    el.setAttribute('font-size',         '20');
    el.setAttribute('font-weight',       '700');
    el.setAttribute('fill',              ACCENT);
    el.setAttribute('text-anchor',       'middle');
    el.setAttribute('dominant-baseline', 'central');
    el.setAttribute('opacity',           '0.3');
    svg.appendChild(el);
    return el;
  });

  svg.style.opacity = '1';

  // ── Animation loop ─────────────────────────────────────────────────────────
  let animTime = 0, lastTS = 0;
  const MAX_CHAR_SPACING = 0.32; // cells between chars at full spread (~15px)

  function updateChars(dt: number) {
    animTime += dt;
    const sf   = spreadFraction();
    const spc  = sf * MAX_CHAR_SPACING; // cells between adjacent chars

    for (let i = 0; i < N; i++) {
      // Float position in trail (chars trail behind lead)
      const tPos = Math.max(0, headFloat - i * spc);
      const { x, y } = trailPos(trail, tPos);

      // Char's own proximity to exit (for rotation)
      const trailIdx = Math.min(Math.floor(tPos), trail.length - 1);
      const [cr, cc] = trail[trailIdx];
      const charProx  = maxDist > 0 ? Math.max(0, 1 - dist[cr][cc] / maxDist) : 0;
      const rAmp     = rotAmp(charProx);

      // Jitter (also fades near exit)
      const jAmt = rAmp * 4;
      const jx   = Math.sin(animTime * 2.3 + i * 1.1) * jAmt;
      const jy   = Math.cos(animTime * 1.8 + i * 0.9) * jAmt;

      // Rotation
      const rot = (initRot[i] + Math.sin(animTime * 2.8 + i * 0.75) * 22) * rAmp;

      const px = (x + jx).toFixed(2);
      const py = (y + jy).toFixed(2);
      const el = charEls[i];
      el.setAttribute('x', px);
      el.setAttribute('y', py);
      el.setAttribute('transform', `rotate(${rot.toFixed(1)},${px},${py})`);
      // Opacity: dim when stacked, bright when separated
      const opac = Math.min(1, 0.3 + sf * 0.7 + (i === 0 ? 0.4 : 0));
      el.setAttribute('opacity', String(opac));
    }
  }

  function frame(ts: number) {
    const dt = Math.min((ts - lastTS) / 1000, 0.05);
    lastTS = ts;

    // Drive lead movement toward cursor while held
    if (mouseHeld && ts - lastMoveMs > MOVE_INTERVAL) {
      const dir = dirTowardMouse();
      if (dir) { tryMove(dir); lastMoveMs = ts; }
    }

    // Smooth lead position animation
    headFloat += (headTarget - headFloat) * 0.22;

    updateChars(dt);

    // Reveal title when lead reaches exit
    const [lr, lc] = trail[headTarget];
    const hint  = document.getElementById('maze-hint');
    const title = document.getElementById('maze-title');
    if (lr === END_R && lc === END_C) {
      if (hint)  hint.style.opacity  = '0';
      if (title) { title.textContent = LABEL; title.style.opacity = '1'; }
    } else {
      const p = leadProximity();
      if (hint)  hint.style.opacity  = String(Math.max(0, 1 - p * 1.5));
      if (title) title.style.opacity = '0';
    }

    requestAnimationFrame(frame);
  }

  requestAnimationFrame(ts => { lastTS = ts; requestAnimationFrame(frame); });
});
</script>

<style>
  .maze-section {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-block: 3rem 1.5rem;
    gap: 0.75rem;
  }

  .maze-wrap {
    position: relative;
    user-select: none;
    touch-action: none;
    max-width: 100%;
    overflow-x: auto;
    cursor: crosshair;
  }

  #maze-svg {
    display: block;
    width: 100%;
    max-width: 632px;
    height: auto;
  }

  .maze-hint {
    color: var(--ink-light);
    font-size: 1rem;
    text-align: center;
    transition: opacity 0.4s;
  }

  .maze-title {
    font-size: clamp(1.8rem, 5vw, 3rem);
    color: var(--ink);
    opacity: 0;
    transition: opacity 0.6s;
    text-align: center;
    min-height: 1.2em;
  }

  .maze-fallback {
    font-size: clamp(2rem, 6vw, 3.5rem);
    color: var(--ink);
    text-align: center;
  }
</style>
